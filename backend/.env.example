# Environment variables for the backend server
# Copy this file to .env and fill in your actual values

# OpenAI API key - get one from https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-your-openai-api-key-here

# Port for the server to listen on
PORT=3000

# Optional: API key for authenticating requests from your mobile app
# Set this to a secure random string if you want to protect your endpoint
API_KEY=your-secure-api-key-here

# Supabase Configuration (Required for Trial Enforcement)
# Get these values from your Supabase project settings:
# 1. Go to https://app.supabase.com/project/YOUR_PROJECT/settings/api
# 2. Copy the Project URL and anon/public key
# 3. Run the SQL migration in backend/supabase_migration.sql in your Supabase SQL Editor
SUPABASE_PROJECT_URL=https://dsmccowwyocitoonvrzc.supabase.co
SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6ImRzbWNjb3d3eW9jaXRvb252cnpjIiwicm9sZSI6ImFub24iLCJpYXQiOjE3NjEyNjUyMDksImV4cCI6MjA3Njg0MTIwOX0.aRFIWsRPHoHpIdTx6uzoodFO7AVve8hFJG67rwfxCho

# ============================================================================
# Stripe Configuration (Superwall Payment Sheet)
# ============================================================================
# These are set as Supabase Edge Function secrets, NOT in the backend .env.
# To set them, run:
#   supabase secrets set STRIPE_WEBHOOK_SECRET=whsec_your-webhook-signing-secret
#
# Get your webhook signing secret from:
#   Stripe Dashboard > Developers > Webhooks > Select your endpoint > Signing secret
#
# Your Stripe webhook endpoint URL should point to:
#   https://<your-project>.supabase.co/functions/v1/stripe-webhook
#
# Events to subscribe to in Stripe:
#   - checkout.session.completed
#   - customer.subscription.created
#   - customer.subscription.updated
#   - customer.subscription.deleted
#   - invoice.payment_succeeded
#   - invoice.payment_failed
STRIPE_WEBHOOK_SECRET=whsec_your-webhook-signing-secret