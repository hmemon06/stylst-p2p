# Copy this file to `.env` and fill in the values.
# Expo automatically loads `EXPO_PUBLIC_*` variables at runtime (restart `expo start` after changes).

# Environment
# Set to 'false' to enable debug menu (long press on logo)
# If not set or set to 'true', debug menu is hidden
EXPO_PUBLIC_PRODUCTION=true

# Backend (required to rate outfits)
# API Configuration (Supabase Edge Functions)
# By default, the app will derive the API URL from EXPO_PUBLIC_SUPABASE_URL
# Use this to override it if needed:
# EXPO_PUBLIC_API_URL=https://your-project.supabase.co/functions/v1/api

# Old Express Backend (Fallback)
EXPO_PUBLIC_RATER_URL=http://localhost:3000/rate
EXPO_PUBLIC_RATER_API_KEY=your-secure-random-string-here

# Supabase (required for device logging + trial/subscription tracking)
EXPO_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=YOUR_SUPABASE_ANON_KEY

# Optional monetization / paywall keys
EXPO_PUBLIC_REVENUECAT_IOS_KEY=
EXPO_PUBLIC_REVENUECAT_ANDROID_KEY=
EXPO_PUBLIC_REVENUECAT_ENTITLEMENT_ID=pro
EXPO_PUBLIC_SUPERWALL_API_KEY=



