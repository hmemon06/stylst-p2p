{
  "expo": {
    "name": "Stylst AI",
    "slug": "stylst-ai",
    "version": "1.1.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "stylst-ai",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "buildNumber": "4",
      "runtimeVersion": {
        "policy": "appVersion"
      },
      "bundleIdentifier": "com.stylst.app",
      "associatedDomains": [
        "applinks:stylst.superwall.app"
      ],
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false,
        "SKIncludeConsumableInAppPurchaseHistory": true,
        "NSAppTransportSecurity": {
          "NSAllowsArbitraryLoads": true,
          "NSAllowsArbitraryLoadsInMedia": true,
          "NSAllowsArbitraryLoadsInLocalNetwork": true
        },
        "NSLocalNetworkUsageDescription": "Allow Stylst AI to reach your secure rating server on the same Wi-Fi network.",
        "NSCameraUsageDescription": "Stylst uses your camera to let you capture photos of your outfits for AI analysis and personalized fashion feedback."
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      },
      "edgeToEdgeEnabled": true,
      "permissions": [
        "android.permission.RECORD_AUDIO",
        "android.permission.RECORD_AUDIO"
      ],
      "package": "com.stylst.app",
      "runtimeVersion": "1.0.0"
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#ffffff"
        }
      ],
      "expo-image-picker",
      "expo-secure-store",
      [
        "expo-build-properties",
        {
          "android": {
            "minSdkVersion": 26
          },
          "ios": {
            "deploymentTarget": "15.1"
          }
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "superwallApiKey": "pk_6i_5eUI3DifyEaQNReTYV",
      "eas": {
        "projectId": "c541c14f-5bbe-4c40-b08d-9246c68863c5"
      }
    },
    "updates": {
      "url": "https://u.expo.dev/c541c14f-5bbe-4c40-b08d-9246c68863c5"
    }
  }
}
